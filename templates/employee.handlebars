<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Employee Details</title>
    <style>
        body { font-family: Arial, sans-serif; max-width: 700px; margin: 40px auto; padding: 0 20px; }
        .morning { background-color: yellow; }
        table { border-collapse: collapse; width: 100%; margin-bottom: 20px; }
        th, td { border: 1px solid #ccc; padding: 8px 12px; text-align: left; }
        th { background: #f0f0f0; }
        .message { color: green; margin: 8px 0; }
        .error { color: red; margin: 8px 0; }
        .upload-section { background: #f9f9f9; border: 1px solid #ddd; padding: 16px; border-radius: 4px; margin-top: 20px; }
        .btn-delete { color: #c00; background: none; border: none; cursor: pointer; text-decoration: underline; font-size: 0.9em; }
        a { color: #1a73e8; }
        .back { margin-top: 20px; display: inline-block; }
    </style>
</head>
<body>
    <h1>Employee Details</h1>
    <p><strong>Name:</strong> {{employee.name}}</p>
    <p><strong>Phone:</strong> {{employee.phone}}</p>
    <a href="/edit/{{employee._id}}">Edit Details</a>

    <h2>Shifts</h2>
    <table>
        <tr>
            <th>Date</th>
            <th>Start Time</th>
            <th>End Time</th>
        </tr>
        {{#each schedule}}
        <tr>
            <td>{{date}}</td>
            <td class="{{#if isMorning}}morning{{/if}}">{{startTime}}</td>
            <td>{{endTime}}</td>
        </tr>
        {{/each}}
    </table>

    <h2>Documents</h2>
    {{#if uploadMessage}}<p class="message">{{uploadMessage}}</p>{{/if}}
    {{#if uploadError}}<p class="error">{{uploadError}}</p>{{/if}}

    {{#if documents.length}}
    <table>
        <tr>
            <th>File Name</th>
            <th>Uploaded</th>
            <th>Action</th>
        </tr>
        {{#each documents}}
        <tr>
            <td><a href="/documents/{{_id}}" target="_blank">{{originalName}}</a></td>
            <td>{{uploadedAt}}</td>
            <td>
                <form method="POST" action="/documents/{{_id}}/delete">
                    <button class="btn-delete" type="submit" onclick="return confirm('Delete this document?')">Delete</button>
                </form>
            </td>
        </tr>
        {{/each}}
    </table>
    {{else}}
    <p>No documents uploaded yet.</p>
    {{/if}}

    <div class="upload-section">
        <strong>Upload Document</strong> (PDF only, max 2 MB, up to 5 per employee)
        <form method="POST" action="/employee/{{employee._id}}/upload" enctype="multipart/form-data">
            <input type="file" name="document" accept=".pdf,application/pdf" required>
            <button type="submit">Upload</button>
        </form>
    </div>

    <a class="back" href="/">Back to Employee List</a>
</body>
</html>