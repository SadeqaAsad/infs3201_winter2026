<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Verify Code</title>
    <style>
        body { font-family: Arial, sans-serif; max-width: 400px; margin: 80px auto; padding: 0 20px; }
        .message { color: red; margin-bottom: 10px; }
        .info { color: #555; font-size: 0.9em; margin-bottom: 16px; }
        label { display: block; margin-bottom: 8px; }
        input { width: 100%; padding: 6px; margin-top: 4px; box-sizing: border-box; font-size: 1.2em; letter-spacing: 4px; }
        button { margin-top: 12px; padding: 8px 20px; }
    </style>
</head>
<body>
    <h1>Two-Factor Authentication</h1>
    <p class="info">A 6-digit code has been sent to your email. It expires in 3 minutes.</p>
    {{#if message}}
    <p class="message">{{message}}</p>
    {{/if}}
    <form method="POST" action="/2fa">
        <label>Enter Code:
            <input type="text" name="code" maxlength="6" autocomplete="one-time-code" required>
        </label>
        <button type="submit">Verify</button>
    </form>
</body>
</html>